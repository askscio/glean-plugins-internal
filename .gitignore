node_modules/
# Build output: the packed runtime for the plugin. Regenerated by
# `npm run build` / `npm run pack:plugin`.
plugins/*/dist/
# Legacy path — kept for transitional cleanliness in case an old build
# leaves a dist/ at the repo root.
dist/
# Packed plugin bundles — produced by scripts/pack-plugin.sh. Not committed;
# marketplace installs pull straight from git. Attach to GitHub releases
# if you want sideload artifacts.
*.plugin
# macOS Finder metadata
.DS_Store
# Temporary userconfig-probe marketplace used during distribution diagnostics
userconfig-probe/
